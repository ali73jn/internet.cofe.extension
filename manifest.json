{
  "manifest_version": 3,
  "name": "همیار کافینت",
  "version": "17",
  "description": "مدیریت پیشرفته بوکمارک ها",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "chrome_url_overrides": {
    "newtab": "dashboard.html"
  },

  "permissions": [
    "storage",
    "bookmarks",
    "tabs"
  ],

  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "file:///*"
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "PerspectiveCrop/index.html",
        "PerspectiveCrop/libs/opencv.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}